# ============================================================
# Obraims MVP — Environment Variables
# Copy this file to .env.local for local development
# ============================================================

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://obraims:obraims@localhost:5432/obraims?schema=public"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Admin access: comma-separated list of admin emails
OBRAIMS_ADMIN_EMAILS="admin@example.com"

# AI Provider: "mock" | "openai" | "anthropic"
AI_PROVIDER="mock"

# Document Extraction Provider
DOCUMENT_EXTRACTOR_PROVIDER="mock"

# File Upload Limits
MAX_UPLOAD_MB="10"
ALLOWED_UPLOAD_MIME_TYPES="application/pdf,image/jpeg,image/png,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"

# Demo Auth (set to "true" to show demo login panel in production)
NEXT_PUBLIC_ENABLE_DEMO_AUTH="false"

# Supabase Storage bucket for documents
OBRAIMS_DOCUMENTS_BUCKET="obraims-documents"
